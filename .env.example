# Database (Amazon Aurora PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/reservflow
DATABASE_READ_URL=postgresql://user:password@localhost:5432/reservflow

# Cache (Amazon ElastiCache Redis)
REDIS_URL=redis://localhost:6379

# Mock Integration Services
MOCK_AIRBNB_URL=http://localhost:3001/api/airbnb
MOCK_BOOKING_URL=http://localhost:3002/api/booking
MOCK_TIMEOUT_MS=5000

# Environment
NODE_ENV=development
